verbose = 2;
log_file = "/var/log/xdpfw.log";
interface = "ens18";
update_time = 15;
no_stats = false;
stats_per_second = false;
stdout_update_time = 1000;

filters = (
    {
        enabled = true,
        action = 1
    },

    // Example: `game` alone auto-fills the protocol/port from Rust's
    // profile (UDP 28015) and only lets the packet through if its payload
    // actually looks like a real RakNet handshake -- not just anything
    // aimed at the port. Games with a well-understood handshake (like
    // this one) also get the spoof-resistant UDP challenge/response
    // system automatically. See README.md's "The `game` filter option"
    // for the full list of supported games and their default ports.
    // {
    //     enabled = true,
    //     action = 1,
    //     game = "rust"
    // }

    // Override the default port if your server doesn't use the
    // conventional one -- any field you set explicitly always wins over
    // the game's profile default.
    // {
    //     enabled = true,
    //     action = 1,
    //     udp_dport = 28016,
    //     game = "rust"
    // }
);