// xdpfw.conf -- runtime configuration. Reloaded automatically every
// `update_time` seconds (see below) -- no restart needed for anything in
// this file. Full reference: README.md.
//
// ============================================================================
// TWO CONFIG TIERS -- READ THIS FIRST
// ============================================================================
// This firewall has two separate places settings live, and they work very
// differently:
//
//   1. THIS FILE (xdpfw.conf) -- runtime settings. Everything below this
//      comment block. Edit and save; the running firewall picks it up on
//      its own within `update_time` seconds (or instantly via `xdpfw-add`/
//      `xdpfw-del`, or `systemctl reload xdpfw`). No rebuild, no restart.
//
//   2. src/common/config.h -- compile-time settings. A handful of advanced
//      protections are OFF by default here and need you to uncomment a
//      `#define` line and rebuild (`make && sudo make install && sudo
//      systemctl restart xdpfw`) to turn on. You will never see these by
//      editing this file -- there is no runtime equivalent, on purpose,
//      since each one changes the shape of the compiled BPF program.
//
// You don't need to touch config.h at all for normal use -- bogon
// filtering, anti-spoofing, amplification protection, ICMP flood
// protection, and the adaptive packet budget are ALL already on by
// default and need zero configuration anywhere. config.h only matters if
// you want one of the features in the cheat sheet below.
//
// ----------------------------------------------------------------------------
// config.h cheat sheet -- what's on by default, and how to turn on what isn't
// ----------------------------------------------------------------------------
// ON by default, no action needed:
//   ENABLE_FILTERS               the `filters` list below actually works
//   ENABLE_IPV6                  IPv6 support throughout
//   ENABLE_RL_FLOW                per-source-flow pps/bps tracking (feeds
//                                 into `flow_pps`/`flow_bps` below)
//   ENABLE_BOGON_FILTER           drop RFC1918/loopback/etc. spoofed sources
//   ENABLE_ANTI_SPOOF              drop bad TCP flags + reflected UDP sources
//   ENABLE_AMP_PROTECTION          drop oversized DNS/NTP/memcached/etc. floods
//   ENABLE_BAD_PAYLOAD_FILTER      drop known flood-tool payload signatures
//   ENABLE_ICMP_PROTECTION         per-IP ICMP flood budget
//   ENABLE_ADAPTIVE_RATE_LIMIT     per-IP TCP/UDP packet budget, auto-blackhole
//   ENABLE_SYN_PROTECTION          SYN-flood OS weighting + subnet-level SYN limits
//   ENABLE_UDP_CHALLENGE           spoof-resistant UDP challenge for `game` rules
//
// OFF by default (edit src/common/config.h, uncomment the line, rebuild):
//   ENABLE_IP_RANGE_DROP           needed for `ip_drop_ranges` below to do anything
//   ENABLE_RL_IP                   per-source-IP (not just flow) pps/bps tracking
//   ENABLE_UDP_ACTIVE_CHALLENGE    active cookie-echo variant of the UDP challenge
//   ENABLE_TOR_RELAY               Tor relay ORPort connection-flood mitigation
//   ENABLE_HANDSHAKE_VERIFY        full TCP connection state tracking (catches
//                                  ACK/RST/FIN floods) -- needs a 2nd attach
//                                  point, see README.md before turning this on
//
// Each flag's own comment in config.h explains what it does and what it
// costs in more detail than fits here -- read it before flipping one on.
// ============================================================================

verbose = 2;
log_file = "/var/log/xdpfw.log";
interface = "ens18";
pin_maps = true;
update_time = 15;      // reload this file + re-apply filters every 15s, no restart needed
no_stats = false;
stats_per_second = true;
stdout_update_time = 1000;

// ============================================================================
// FILTERS -- everything below is optional. With an empty list (the
// default), you already get the always-on protection described above on
// every port. Add a rule here only when you want to:
//   (a) validate a specific game/app's traffic (payload signatures,
//       auto-filled ports, spoof-resistant challenges), or
//   (b) apply extra scrutiny (a tighter rate limit, an outright IP block)
//       beyond the always-on baseline.
// ============================================================================
filters = (
    // --- Game server examples ---

    // Rust: `game` alone auto-fills the protocol/port from Rust's profile
    // (UDP 28015) and requires the payload to actually look like a real
    // RakNet handshake (or a bare Source-engine-style query), not just
    // anything aimed at the port. Also gets the spoof-resistant UDP
    // challenge/response system automatically. See README.md's "The
    // `game` filter option" for the full profile table (16 supported
    // games) and which ones get the challenge system.
    // {
    //     enabled = true,
    //     action = 1,
    //     game = "rust"
    // },

    // Same game, but your server doesn't use the conventional port: any
    // field you set explicitly always overrides the profile default.
    // {
    //     enabled = true,
    //     action = 1,
    //     udp_dport = 28016,
    //     game = "rust"
    // },

    // TeamSpeak 3: this is literally all it takes. `game = "ts3"`
    // auto-fills UDP 9000-10500 (covers the conventional single-instance
    // default of 9987 plus the range real TS3 hosting uses for multiple
    // virtual server instances -- override with udp_dport if yours is
    // narrower/different) and validates the payload against TS3's real
    // "TS3INIT1" handshake preamble, with the spoof-resistant challenge
    // system layered on top automatically.
    // {
    //     enabled = true,
    //     action = 1,
    //     game = "ts3"
    // },

    // FiveM needs two rules: `game = "fivem"` alone covers its UDP side
    // (auto-filled to port 30120, RakNet-validated, challenge-protected).
    // Its separate TCP side (HTTP/NUI/asset streaming) needs its own
    // plain rule WITHOUT `game` -- FiveM's profile is UDP-only, so tagging
    // the TCP rule with `game = "fivem"` would require RakNet-shaped
    // payloads on HTTP traffic and block everything.
    // {
    //     enabled = true,
    //     action = 1,
    //     game = "fivem"
    // },
    // {
    //     enabled = true,
    //     action = 1,
    //     tcp_enabled = true,
    //     tcp_dport = "30000-32000"
    // },

    // --- Generic app examples (no `game` -- just header matching) ---

    // SSH, rate-limited per source flow to blunt brute-force/credential-
    // stuffing attempts without touching the always-on adaptive budget's
    // more generous default.
    // {
    //     enabled = true,
    //     action = 1,
    //     tcp_enabled = true,
    //     tcp_dport = 22,
    //     flow_pps = 20
    // },

    // A web server, allowing HTTPS through with its own tighter
    // connection-rate cap than the global adaptive default.
    // {
    //     enabled = true,
    //     action = 1,
    //     tcp_enabled = true,
    //     tcp_dport = 443,
    //     flow_pps = 500
    // },

    // Explicitly block a specific troublemaker IP outright. Prefer
    // `xdpfw-add -m 2 -d 203.0.113.66 -e 3600` for this at runtime
    // instead (no config edit/reload needed, and supports an expiry) --
    // see README.md's xdpfw-add/xdpfw-del section. This is just what the
    // equivalent rule looks like written directly in this file.
    // {
    //     enabled = true,
    //     action = 0,
    //     src_ip = "203.0.113.66"
    // }
);

// Whole CIDR ranges to drop outright. Requires ENABLE_IP_RANGE_DROP in
// src/common/config.h (off by default -- see the cheat sheet above) --
// entries here are silently ignored otherwise. Prefer `xdpfw-add -m 1`
// for adding one at runtime instead of editing this list by hand.
ip_drop_ranges = ( );
